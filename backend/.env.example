# ─────────────────────────────────────────────────────────────────
# PhishCatch AI – Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_NAME="PhishCatch AI"

# ── Database ────────────────────────────────────────────────────────
# Default: SQLite — no installation required. A file `phishcatch.db`
# will be created automatically in the backend/ directory.
DATABASE_URL=sqlite+aiosqlite:///./phishcatch.db
#
# For production, swap to PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/phishcatch

# ── JWT Authentication ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_64_CHARS_MINIMUM
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Provider ───────────────────────────────────────────────────
# Set ONLY ONE of the following:
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# (Optional) Anthropic Claude instead of OpenAI
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Rate Limiting ─────────────────────────────────────────────────
# Max analysis requests per user per hour
RATE_LIMIT_ANALYSIS_PER_HOUR=20

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Input Constraints ────────────────────────────────────────────
MAX_EMAIL_INPUT_BYTES=51200    # 50 KB – prevents token bombing the LLM
